# ── Client (Vite) ─────────────────────────────────────────────────────────
# Supabase project URL + anon (publishable) key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Comma-separated emails that bypass the subscription paywall (owner / comped /
# internal). Leave empty so nobody bypasses. Set this in Vercel for prod too.
VITE_COMP_ACCESS_EMAILS=

# Sentry DSN for error monitoring. Leave empty to disable (the SDK chunk is not
# even loaded without it). Set in Vercel to capture production errors.
VITE_SENTRY_DSN=

# ── Server (Vercel functions + Vite dev middleware) ───────────────────────
# Anthropic key powering the /api/* AI endpoints. Required in prod.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-haiku-4-5).
ANTHROPIC_MODEL=

# ── Supabase Edge Functions (set as Supabase secrets, not here) ───────────
# Stripe billing: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_ID_99,
#   STRIPE_PRICE_ID_199, SITE_URL
# Account deletion + checkout: SUPABASE_SERVICE_ROLE_KEY (+ SUPABASE_URL/ANON_KEY)
